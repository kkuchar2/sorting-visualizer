{
  "name": "react-sorting-visualizer",
  "version": "1.0.0",
  "author": "Krzysztof Kucharski",
  "license": "MIT",
  "description": "Visualisation of common soring algorithms with ThreeJS and webworker",
  "keywords": [
    "react",
    "threejs",
    "nextjs"
  ],
  "scripts": {
    "predev": "node scripts/embed-sort-sources.mjs",
    "prebuild": "node scripts/embed-sort-sources.mjs",
    "dev": "next dev --webpack -p 3002",
    "build": "next build --webpack",
    "preview": "npx serve out -p 3002",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "@react-hook/throttle": "^2.2.0",
    "@react-three/fiber": "^9.1.2",
    "@wooorm/starry-night": "^3.10.0",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "next": "16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.175.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.185.0",
    "eslint": "^10.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-tailwindcss": "4.0.6",
    "prettier": "^3.9.4",
    "sass": "^1.86.3",
    "tailwindcss": "^4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  },
  "packageManager": "pnpm@11.9.0"
}
